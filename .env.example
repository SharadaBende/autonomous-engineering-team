# Example environment variables file for TodoApp
# This file should be renamed to .env and updated with your own values

# Database connection settings
DB_HOST=localhost
DB_PORT=3306
DB_USER=todoapp
DB_PASSWORD=${TODOAPP_DB_PASSWORD}
DB_NAME=todoapp

# Redis cache settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=${TODOAPP_REDIS_PASSWORD}

# Node.js server settings
NODE_ENV=production
SERVER_PORT=3000

# React frontend settings
REACT_APP_API_URL=http://localhost:3000/api

# Docker settings
DOCKER_COMPOSE_PROJECT_NAME=todoapp

# Security settings
TODOAPP_SECRET_KEY=${TODOAPP_SECRET_KEY}
TODOAPP_JWT_SECRET=${TODOAPP_JWT_SECRET}

# Logging settings
LOG_LEVEL=info
LOG_FILE=/var/log/todoapp.log

# MySQL connection settings for Docker
MYSQL_ROOT_PASSWORD=${TODOAPP_MYSQL_ROOT_PASSWORD}
MYSQL_DATABASE=todoapp
MYSQL_USER=todoapp
MYSQL_PASSWORD=${TODOAPP_MYSQL_PASSWORD}